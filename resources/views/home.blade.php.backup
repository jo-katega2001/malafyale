      .featured-video-card .card-title {
        font-size: 1.25rem;
      }

      /* ── Video Lightbox ── */
      #videoLightbox {
        position: fixed;
        inset: 0;
        z-index: 80;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(4,10,20,0.92);
        backdrop-filter: blur(8px);
        padding: 16px;
      }
      #videoLightbox.open {
        display: flex;
      }
      #videoLightbox .lb-inner {
        position: relative;
        width: 100%;
        max-width: 900px;
        border-radius: 24px;
        overflow: hidden;
        background: #000;
        box-shadow: 0 40px 120px rgba(0,0,0,0.7);
      }
      #videoLightbox video {
        width: 100%;
        display: block;
        max-height: 80vh;
        background: #000;
      }
      #videoLightbox .lb-close {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 10;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,0.15);
