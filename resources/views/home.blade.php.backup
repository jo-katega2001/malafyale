      /* ── Video Gallery ── */
      .video-card {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        cursor: pointer;
        background: #081423;
        box-shadow: 0 14px 40px rgba(16,35,60,0.18);
        transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.28s ease;
      }
      .video-card:hover {
        transform: translateY(-6px) scale(1.015);
        box-shadow: 0 28px 60px rgba(8,20,35,0.32);
      }
      .video-card img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        display: block;
        transition: opacity 0.3s ease;
      }
      .video-card:hover img {
        opacity: 0.82;
      }
      .video-card .play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(to top, rgba(8,20,35,0.72) 0%, transparent 55%);
        transition: background 0.28s ease;
      }
      .video-card:hover .play-overlay {
        background: linear-gradient(to top, rgba(8,20,35,0.85) 0%, rgba(8,20,35,0.18) 55%);
      }
      .play-btn {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(199,150,77,0.92);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 32px rgba(199,150,77,0.45);
        transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), background 0.2s ease;
        flex-shrink: 0;
      }
      .video-card:hover .play-btn {
        transform: scale(1.18);
        background: #c7964d;
      }
      .play-btn svg {
        width: 26px;
        height: 26px;
        fill: #081423;
        margin-left: 4px;
      }
      .video-card .card-meta {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 18px 20px 20px;
      }
      .video-card .card-duration {
        display: inline-flex;
        align-items: center;
        background: rgba(8,20,35,0.75);
        backdrop-filter: blur(6px);
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        padding: 3px 10px;
        border-radius: 999px;
        margin-bottom: 8px;
      }
      .video-card .card-title {
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        line-height: 1.4;
        font-family: "Trebuchet MS", "Avenir Next", sans-serif;
        text-shadow: 0 2px 8px rgba(0,0,0,0.6);
